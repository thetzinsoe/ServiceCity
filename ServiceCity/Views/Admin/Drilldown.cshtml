@model ServiceCity.Services.DTOs.AdminDashboardDto
@{
    ViewData["Title"] = "Bookings";

    var status = Model.StatusFilter != null
        ? Enum.TryParse<ServiceCity.Core.Enums.BookingStatus>(Model.StatusFilter, true, out var parsed) ? parsed : (ServiceCity.Core.Enums.BookingStatus?)null
        : null;

    var statusStyles = new Dictionary<ServiceCity.Core.Enums.BookingStatus, (string bg, string text)>
    {
        [ServiceCity.Core.Enums.BookingStatus.Pending] = ("#fff3cd", "#856404"),
        [ServiceCity.Core.Enums.BookingStatus.Accepted] = ("#cce5ff", "#004085"),
        [ServiceCity.Core.Enums.BookingStatus.InProgress] = ("#fff3cd", "#856404"),
        [ServiceCity.Core.Enums.BookingStatus.Completed] = ("#d4edda", "#155724"),
        [ServiceCity.Core.Enums.BookingStatus.Declined] = ("#f8d7da", "#721c24"),
    };
    var statusIcons = new Dictionary<ServiceCity.Core.Enums.BookingStatus, string>
    {
        [ServiceCity.Core.Enums.BookingStatus.Pending] = "🟡",
        [ServiceCity.Core.Enums.BookingStatus.Accepted] = "🔵",
        [ServiceCity.Core.Enums.BookingStatus.InProgress] = "🟠",
        [ServiceCity.Core.Enums.BookingStatus.Completed] = "🟢",
        [ServiceCity.Core.Enums.BookingStatus.Declined] = "🔴",
    };

    var currentStatus = status ?? ServiceCity.Core.Enums.BookingStatus.Pending;
    var style = statusStyles[currentStatus];
    var count = Model.Counts.GetValueOrDefault(currentStatus, 0);
}

<a asp-action="Dashboard" class="text-muted text-decoration-none small">← Back to Dashboard</a>

<div class="page-header mt-2">
    <h2 class="page-title">@statusIcons[currentStatus] @currentStatus</h2>
    <span class="badge rounded-pill page-count" style="background:@style.bg; color:@style.text;">@count</span>
    <form asp-action="Drilldown" method="get" class="page-search">
        <input type="hidden" name="status" value="@Model.StatusFilter" />
        <div class="input-group input-group-sm">
            <input type="text" name="search" value="@Model.Search" class="form-control"
                   placeholder="Search phone, ref, name…" />
            <button type="submit" class="btn btn-primary">Search</button>
            @if (!string.IsNullOrWhiteSpace(Model.Search))
            {
                <a asp-action="Drilldown" asp-route-status="@Model.StatusFilter" class="btn btn-outline-secondary">Clear</a>
            }
        </div>
    </form>
</div>

@{
    var hasBookings = Model.GroupedBookings.TryGetValue(currentStatus, out var bookings) && bookings!.Any();
}

@if (hasBookings)
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
        @foreach (var booking in bookings!)
        {
            var isToday = booking.CreatedAt.Date == DateTime.UtcNow.Date;
            <div class="col">
                <a asp-action="Details" asp-route-id="@booking.Id" class="text-decoration-none">
                    <div class="card booking-card h-100">
                        @if (isToday)
                        {
                            <span class="badge bg-danger position-absolute top-0 start-0 ms-2 mt-2" style="z-index:1;">New</span>
                        }
                        <div class="card-body">
                            <h5 class="card-title fw-bold mb-1">@booking.CustomerName</h5>
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <span class="badge rounded-pill" style="background:@style.bg; color:@style.text;">@booking.Status</span>
                                <span class="text-muted small">@booking.ServiceCategoryName</span>
                            </div>
                            <div class="d-flex gap-3 text-muted small">
                                <span>📅 @booking.PreferredDate.ToLocalTime().ToString("dd/MM")</span>
                                <span>🕐 @booking.PreferredTimeSlot</span>
                            </div>
                            <div class="mt-2">
                                <small class="text-muted">@booking.ReferenceNumber</small>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
}
else
{
    <div class="text-muted small py-2">No bookings in this status.</div>
}
