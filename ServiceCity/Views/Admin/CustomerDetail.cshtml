@model List<ServiceCity.Services.DTOs.BookingListItemDto>
@{
    ViewData["Title"] = "Customer — " + (ViewBag.Customer?.Name ?? "");
    var customer = ViewBag.Customer as ServiceCity.Services.DTOs.UserDto;
}

<div class="mb-3">
    <a asp-action="Customers" class="text-decoration-none text-muted small">&larr; Back to Customers</a>
</div>

@if (customer != null)
{
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h3 class="h5 fw-bold mb-2">@customer.Name</h3>
            <div class="row text-muted small">
                <div class="col-auto">
                    <strong>Phone:</strong> @customer.PhoneNumber
                </div>
                @if (!string.IsNullOrEmpty(customer.Address))
                {
                    <div class="col-auto">
                        <strong>Address:</strong> @customer.Address
                    </div>
                }
                <div class="col-auto">
                    <strong>Member since:</strong> @customer.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")
                </div>
            </div>
        </div>
    </div>
}

<div class="page-header">
    <h2 class="page-title" style="font-size:1rem;">Booking History</h2>
    <span class="badge bg-primary page-count">@Model.Count bookings</span>
</div>

@if (!Model.Any())
{
    <div class="text-muted small py-3">No bookings yet.</div>
}
else
{
    var statusStyles = new Dictionary<ServiceCity.Core.Enums.BookingStatus, (string bg, string text)>
    {
        [ServiceCity.Core.Enums.BookingStatus.Pending] = ("#fff3cd", "#856404"),
        [ServiceCity.Core.Enums.BookingStatus.Accepted] = ("#cce5ff", "#004085"),
        [ServiceCity.Core.Enums.BookingStatus.InProgress] = ("#fff3cd", "#856404"),
        [ServiceCity.Core.Enums.BookingStatus.Completed] = ("#d4edda", "#155724"),
        [ServiceCity.Core.Enums.BookingStatus.Declined] = ("#f8d7da", "#721c24"),
    };
    var statusIcons = new Dictionary<ServiceCity.Core.Enums.BookingStatus, string>
    {
        [ServiceCity.Core.Enums.BookingStatus.Pending] = "🟡",
        [ServiceCity.Core.Enums.BookingStatus.Accepted] = "🔵",
        [ServiceCity.Core.Enums.BookingStatus.InProgress] = "🟠",
        [ServiceCity.Core.Enums.BookingStatus.Completed] = "🟢",
        [ServiceCity.Core.Enums.BookingStatus.Declined] = "🔴",
    };

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
        @foreach (var booking in Model)
        {
            var style = statusStyles.GetValueOrDefault(booking.Status, ("#e9ecef", "#383d41"));
            var icon = statusIcons.GetValueOrDefault(booking.Status, "⚪");
            var badgeBg = style.Item1;
            var badgeText = style.Item2;
            <div class="col">
                <a asp-action="Details" asp-route-id="@booking.Id" class="text-decoration-none">
                    <div class="card booking-card h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title fw-bold mb-0">@booking.ServiceCategoryName</h5>
                                <span class="badge rounded-pill" style="background:@badgeBg; color:@badgeText;">@icon @booking.Status</span>
                            </div>
                            <div class="d-flex gap-3 text-muted small mb-1">
                                <span>@booking.PreferredDate.ToLocalTime().ToString("dd/MM")</span>
                                <span>@booking.PreferredTimeSlot</span>
                            </div>
                            <small class="text-muted">@booking.ReferenceNumber</small>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
}
