@model ServiceCity.Services.DTOs.AdminDashboardDto
@{
    ViewData["Title"] = "Bookings";
}

@{
    var total = Model.Counts.Values.Sum();
    var pendingCount = Model.Counts.GetValueOrDefault(ServiceCity.Core.Enums.BookingStatus.Pending, 0);
}

<div class="page-header">
    <h2 class="page-title">Bookings</h2>
    <span class="badge bg-primary page-count">@total total · @pendingCount pending</span>
    <form asp-action="Dashboard" method="get" class="page-search">
        <div class="input-group input-group-sm">
            <input type="text" name="search" value="@Model.Search" class="form-control"
                   placeholder="Search phone, ref, name…" />
            <button type="submit" class="btn btn-primary">Search</button>
            @if (!string.IsNullOrWhiteSpace(Model.Search))
            {
                <a asp-action="Dashboard" class="btn btn-outline-secondary">Clear</a>
            }
        </div>
    </form>
</div>

@{
    var statusOrder = new[] {
        ServiceCity.Core.Enums.BookingStatus.Pending,
        ServiceCity.Core.Enums.BookingStatus.Accepted,
        ServiceCity.Core.Enums.BookingStatus.InProgress,
        ServiceCity.Core.Enums.BookingStatus.Completed,
        ServiceCity.Core.Enums.BookingStatus.Declined
    };
    var statusStyles = new Dictionary<ServiceCity.Core.Enums.BookingStatus, (string bg, string text)>
    {
        [ServiceCity.Core.Enums.BookingStatus.Pending] = ("#fff3cd", "#856404"),
        [ServiceCity.Core.Enums.BookingStatus.Accepted] = ("#cce5ff", "#004085"),
        [ServiceCity.Core.Enums.BookingStatus.InProgress] = ("#fff3cd", "#856404"),
        [ServiceCity.Core.Enums.BookingStatus.Completed] = ("#d4edda", "#155724"),
        [ServiceCity.Core.Enums.BookingStatus.Declined] = ("#f8d7da", "#721c24"),
    };
    var statusIcons = new Dictionary<ServiceCity.Core.Enums.BookingStatus, string>
    {
        [ServiceCity.Core.Enums.BookingStatus.Pending] = "🟡",
        [ServiceCity.Core.Enums.BookingStatus.Accepted] = "🔵",
        [ServiceCity.Core.Enums.BookingStatus.InProgress] = "🟠",
        [ServiceCity.Core.Enums.BookingStatus.Completed] = "🟢",
        [ServiceCity.Core.Enums.BookingStatus.Declined] = "🔴",
    };
}

@if (total > 0)
{
    <div class="row row-cols-2 row-cols-md-3 row-cols-lg-5 g-3 mb-4">
        @foreach (var status in statusOrder)
        {
            var count = Model.Counts.GetValueOrDefault(status, 0);
            var style = statusStyles[status];
            <div class="col">
                <a asp-action="Drilldown" asp-route-status="@status" class="status-card card"
                   style="background:@style.bg; color:@style.text;">
                    <div class="status-icon">@statusIcons[status]</div>
                    <div class="status-label">@status</div>
                    <div class="status-count">@count</div>
                </a>
            </div>
        }
    </div>
}
else
{
    <div class="text-center py-5">
        <p class="text-muted fs-5">No bookings yet.</p>
        <p class="text-muted small">Bookings will appear here when customers submit them.</p>
    </div>
}
