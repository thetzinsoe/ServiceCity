@model List<ServiceCity.Services.DTOs.CustomerListItemDto>
@{
    ViewData["Title"] = "Customers";
}

<div class="page-header">
    <h2 class="page-title">Customers</h2>
    <span class="badge bg-primary page-count">@Model.Count total</span>
    <form asp-action="Customers" method="get" class="page-search">
        <div class="input-group input-group-sm">
            <input type="text" name="search" value="@Context.Request.Query["search"]" class="form-control"
                   placeholder="Search name, phone…" />
            <button type="submit" class="btn btn-primary">Search</button>
            @if (!string.IsNullOrEmpty(Context.Request.Query["search"]))
            {
                <a asp-action="Customers" class="btn btn-outline-secondary">Clear</a>
            }
        </div>
    </form>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <p class="text-muted fs-5">No customers yet.</p>
        <p class="text-muted small">Customers will appear here after they register and book.</p>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
        @foreach (var customer in Model)
        {
            <div class="col">
                <a asp-action="CustomerDetail" asp-route-id="@customer.Id" class="text-decoration-none">
                    <div class="card booking-card h-100">
                        <div class="card-body">
                            <h5 class="card-title fw-bold mb-1">@customer.Name</h5>
                            <p class="card-text text-muted small mb-2">@customer.PhoneNumber</p>
                            <div class="d-flex align-items-center gap-2">
                                <span class="badge bg-primary rounded-pill">@customer.BookingCount booking@(customer.BookingCount != 1 ? "s" : "")</span>
                                @if (customer.LastBooking.HasValue)
                                {
                                    <span class="text-muted small">Last: @customer.LastBooking.Value.ToLocalTime().ToString("dd/MM/yy")</span>
                                }
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
}
