@model List<ServiceCity.Models.CustomerViewModel>
@{
    ViewData["Title"] = "Customers";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="h4 fw-bold mb-0">Customers</h2>
    <span class="badge bg-primary fs-6">@Model.Count total</span>
</div>

<form asp-action="Customers" method="get" class="mb-4">
    <div class="input-group">
        <span class="input-group-text bg-white border-end-0">🔍</span>
        <input type="text" name="search" value="@Context.Request.Query["search"]" class="form-control border-start-0"
               placeholder="Search by name or phone…" />
        @if (!string.IsNullOrEmpty(Context.Request.Query["search"]))
        {
            <a asp-action="Customers" class="btn btn-outline-secondary">Clear</a>
        }
        <button type="submit" class="btn btn-primary px-3">Search</button>
    </div>
</form>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <p class="text-muted fs-5">No customers yet.</p>
        <p class="text-muted small">Customers will appear here after they register and book.</p>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
        @foreach (var customer in Model)
        {
            <div class="col">
                <a asp-action="CustomerDetail" asp-route-id="@customer.Id" class="text-decoration-none">
                    <div class="card booking-card h-100">
                        <div class="card-body">
                            <h5 class="card-title fw-bold mb-1">@customer.Name</h5>
                            <p class="card-text text-muted small mb-2">@customer.PhoneNumber</p>
                            <div class="d-flex align-items-center gap-2">
                                <span class="badge bg-primary rounded-pill">@customer.BookingCount booking@(customer.BookingCount != 1 ? "s" : "")</span>
                                @if (customer.LastBooking.HasValue)
                                {
                                    <span class="text-muted small">Last: @customer.LastBooking.Value.ToLocalTime().ToString("dd/MM/yy")</span>
                                }
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
}
