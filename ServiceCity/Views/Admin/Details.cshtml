@model ServiceCity.Core.Entities.Booking
@{
    ViewData["Title"] = "Booking Details - " + Model.ReferenceNumber;
}

<h2 class="h4 mb-4">Booking Details: @Model.ReferenceNumber</h2>

<div class="card">
    <div class="card-body">
        <p><strong>Customer Name:</strong> @Model.CustomerName</p>
        <p><strong>Phone:</strong> @Model.CustomerPhone</p>
        <p><strong>Service:</strong> @Model.ServiceCategory.Name</p>
        <p><strong>Address:</strong> @Model.Address</p>
        <p><strong>Description:</strong> @(Model.Description ?? "N/A")</p>
        <p><strong>Date:</strong> @Model.PreferredDate.ToShortDateString()</p>
        <p><strong>Time Slot:</strong> @Model.PreferredTimeSlot</p>
        <p><strong>Status:</strong> @Model.Status</p>
        <p><strong>Created:</strong> @Model.CreatedAt.ToLocalTime()</p>
    </div>
</div>

@if (Model.Status == ServiceCity.Core.Enums.BookingStatus.Pending)
{
    <div class="card mt-3">
        <div class="card-body">
            <h5 class="card-title">Admin Actions</h5>
            <div class="row g-3">
                <div class="col-md-6">
                    <form asp-action="Accept" method="post">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <label class="form-label">Estimated Arrival</label>
                        <input type="datetime-local" name="arrivalTime" class="form-control" required />
                        <button type="submit" class="btn btn-success mt-2">Accept</button>
                    </form>
                </div>
                <div class="col-md-6">
                    <form asp-action="Decline" method="post">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <label class="form-label">Reason</label>
                        <textarea name="reason" class="form-control" required></textarea>
                        <button type="submit" class="btn btn-danger mt-2">Decline</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

<div class="mt-3">
    <a asp-action="Dashboard" class="btn btn-primary">Back to Dashboard</a>
</div>
