@model ServiceCity.Core.Entities.Booking
@{
    ViewData["Title"] = "Booking Details - " + Model.ReferenceNumber;
}

<h2 class="h4 mb-4">Booking Details: @Model.ReferenceNumber</h2>

<div class="card">
    <div class="card-body">
        <p><strong>Customer Name:</strong> @Model.CustomerName</p>
        <p><strong>Phone:</strong> @Model.CustomerPhone</p>
        <p><strong>Service:</strong> @Model.ServiceCategory.Name</p>
        <p><strong>Address:</strong> @Model.Address</p>
        <p><strong>Description:</strong> @(Model.Description ?? "N/A")</p>
        <p><strong>Date:</strong> @Model.PreferredDate.ToLocalTime().ToString("dd/MM/yyyy")</p>
        <p><strong>Time Slot:</strong> @Model.PreferredTimeSlot</p>
        <p><strong>Status:</strong> @Model.Status</p>
        <p><strong>Created:</strong> @Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy hh:mm tt")</p>
    </div>
</div>

@if (Model.Status == ServiceCity.Core.Enums.BookingStatus.Pending)
{
    <div class="card mt-3">
        <div class="card-body">
            <h5 class="card-title">Admin Actions</h5>
            <div class="row g-3">
                <div class="col-md-6">
                    <form asp-action="Accept" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <label class="form-label">Estimated Arrival</label>
                        <input type="datetime-local" name="arrivalTime" class="form-control" required />
                        <button type="submit" class="btn btn-success mt-2 w-100">Accept Booking</button>
                    </form>
                </div>
                <div class="col-md-6">
                    <form asp-action="Decline" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <label class="form-label">Decline Reason</label>
                        <textarea name="reason" class="form-control" required placeholder="Reason for declining..."></textarea>
                        <button type="submit" class="btn btn-danger mt-2 w-100">Decline Booking</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}
else if (Model.Status == ServiceCity.Core.Enums.BookingStatus.Accepted)
{
    <div class="card mt-3 border-primary">
        <div class="card-body">
            <h5 class="card-title">Admin Actions</h5>
            <p>Estimated Arrival: <strong>@Model.EstimatedArrivalTime?.ToLocalTime().ToString("g")</strong></p>
            <form asp-action="InProgress" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="btn btn-primary w-100">Mark In Progress</button>
            </form>
        </div>
    </div>
}
else if (Model.Status == ServiceCity.Core.Enums.BookingStatus.InProgress)
{
    <div class="card mt-3 border-warning">
        <div class="card-body">
            <h5 class="card-title">Admin Actions</h5>
            <form asp-action="Complete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="btn btn-success w-100">Mark Complete</button>
            </form>
        </div>
    </div>
}

<div class="mt-3">
    <a asp-action="Dashboard" class="btn btn-primary">Back to Dashboard</a>
</div>
