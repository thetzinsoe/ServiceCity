@model ServiceCity.Models.ErrorViewModel
@{
    ViewData["Title"] = Model.StatusCode switch
    {
        404 => "Page Not Found",
        403 => "Access Denied",
        503 => "Service Unavailable",
        _ => "Something Went Wrong"
    };

    var (icon, title, subtitle, suggestion) = Model.StatusCode switch
    {
        404 => (
            "🔍",
            "We couldn't find that page",
            "The page you're looking for doesn't exist or has been moved.",
            "Double-check the link, or go back to the home page."
        ),
        403 => (
            "🔒",
            "Access Denied",
            "You don't have permission to view this page.",
            "Try signing in with an account that has access, or return home."
        ),
        503 => (
            "⏳",
            "Service Temporarily Unavailable",
            "We're doing a bit of maintenance, or there's a temporary issue.",
            "Please try again in a few minutes. We'll be back shortly!"
        ),
        _ => (
            "🔧",
            "Something Went Wrong",
            "An unexpected error occurred while processing your request.",
            "Our team has been notified. Please try again, or head back home."
        )
    };
}

<div class="error-page text-center py-5">
    <div class="error-icon mb-4">@icon</div>

    <div class="error-code mb-3">@Model.StatusCode</div>

    <h1 class="h3 fw-bold mb-3">@title</h1>

    <p class="text-muted mb-2">@subtitle</p>
    <p class="text-muted small mb-4">@suggestion</p>

    <div class="d-flex justify-content-center gap-3 flex-wrap">
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary px-4">
            🏠 Go Home
        </a>
        @if (Model.StatusCode == 403 && User.Identity?.IsAuthenticated != true)
        {
            <a asp-controller="Auth" asp-action="SignIn" class="btn btn-outline-primary px-4">
                🔑 Sign In
            </a>
        }
    </div>

    @if (Model.ShowRequestId)
    {
        <p class="text-muted mt-4" style="font-size: 0.75rem;">
            Request ID: <code>@Model.RequestId</code>
        </p>
    }
</div>

<style>
    .error-page {
        min-height: 60vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
    }
    .error-icon {
        font-size: 4rem;
        line-height: 1;
    }
    .error-code {
        font-size: 5rem;
        font-weight: 800;
        line-height: 1;
        color: var(--sc-blue);
        opacity: 0.3;
        letter-spacing: -2px;
    }
</style>
