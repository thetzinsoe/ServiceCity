<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ServiceCity</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ServiceCity.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-md navbar-dark sticky-top">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">🔧 ServiceCity</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain"
                        aria-controls="navbarMain" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse" id="navbarMain">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Admin" asp-action="Customers">Customers</a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="bookDropdown" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                Book a Service
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="bookDropdown">
                                <li><a class="dropdown-item" asp-controller="Booking" asp-action="Create" asp-route-serviceCategoryId="1">🔧 Repair</a></li>
                                <li><a class="dropdown-item" asp-controller="Booking" asp-action="Create" asp-route-serviceCategoryId="2">🧹 Maintenance</a></li>
                                <li><a class="dropdown-item" asp-controller="Booking" asp-action="Create" asp-route-serviceCategoryId="3">📦 Installation</a></li>
                                <li><a class="dropdown-item" asp-controller="Booking" asp-action="Create" asp-route-serviceCategoryId="4">❄️ Gas Refill</a></li>
                            </ul>
                        </li>
                    }
                    @if (User.Identity?.IsAuthenticated == true && !User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Booking" asp-action="MyBookings">My Bookings</a>
                        </li>
                    }
                    </ul>
                    <ul class="navbar-nav ms-auto">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle profile-dropdown-toggle d-flex align-items-center" href="#"
                               id="profileDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <span class="me-1">👤</span> @User.Identity.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="profileDropdown">
                                <li><h6 class="dropdown-header">Signed in as<br/><strong>@User.Identity.Name</strong></h6></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><a class="dropdown-item" asp-controller="Auth" asp-action="Settings">⚙️ Settings</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <form asp-controller="Auth" asp-action="SignOut" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item text-danger">Sign Out</button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Auth" asp-action="Register">Register</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Auth" asp-action="SignIn">Sign In</a>
                        </li>
                    }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container pt-3">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="footer mt-auto">
        <div class="container text-center">
            <span>&copy; 2026 ServiceCity</span>
            <span class="divider">·</span>
            <a asp-controller="Home" asp-action="Privacy">Privacy</a>
            <span class="divider">·</span>
            <a asp-controller="Home" asp-action="Index">Home</a>
        </div>
    </footer>

    <script src="https://unpkg.com/htmx.org@2.0.0"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
