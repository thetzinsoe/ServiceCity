@model List<ServiceCity.Services.DTOs.BookingListItemDto>
@{
    ViewData["Title"] = "Search Results";
}

<div class="page-header">
    <h2 class="page-title">Search Results</h2>
    <span class="badge bg-primary page-count">@Model.Count found</span>
    <a asp-action="Track" class="btn btn-outline-secondary btn-sm page-search">New Search</a>
</div>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">No bookings found matching your search.</div>
}
else
{
    <div class="table-responsive">
        <table class="table">
        <thead>
            <tr>
                <th>Reference</th>
                <th>Customer</th>
                <th>Service</th>
                <th>Status</th>
                <th>Date</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var booking in Model)
            {
                <tr>
                    <td>@booking.ReferenceNumber</td>
                    <td>@booking.CustomerName</td>
                    <td>@booking.ServiceCategoryName</td>
                    <td>@booking.Status</td>
                    <td>@booking.PreferredDate.ToLocalTime().ToString("dd/MM/yyyy")</td>
                    <td><a asp-action="Status" asp-route-referenceNumber="@booking.ReferenceNumber" class="btn btn-sm btn-outline-primary">View</a></td>
                </tr>
            }
        </tbody>
    </table>
    </div>
}
