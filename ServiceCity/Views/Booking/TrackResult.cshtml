@model List<ServiceCity.Core.Entities.Booking>
@{
    ViewData["Title"] = "Your Bookings";
}

<h2 class="h4 mb-4">Your Bookings</h2>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">No bookings found for this phone number.</div>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Reference</th>
                <th>Service</th>
                <th>Status</th>
                <th>Date</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var booking in Model)
            {
                <tr>
                    <td>@booking.ReferenceNumber</td>
                    <td>@booking.ServiceCategory.Name</td>
                    <td>@booking.Status</td>
                    <td>@booking.PreferredDate.ToShortDateString()</td>
                    <td><a asp-action="Status" asp-route-referenceNumber="@booking.ReferenceNumber" class="btn btn-sm btn-outline-primary">View</a></td>
                </tr>
            }
        </tbody>
    </table>
}
