@model ServiceCity.Core.Entities.Booking
@{
    ViewData["Title"] = "Booking Confirmed";
}

<div class="card">
    <div class="card-body">
        <h2 class="h4">Booking Confirmed</h2>
        <p>Your booking has been received. Please keep your reference number for tracking.</p>
        
        <div class="alert alert-success">
            <strong>Reference Number:</strong> @Model.ReferenceNumber
        </div>

        <p><strong>Service:</strong> @Model.ServiceCategory.Name</p>
        <p><strong>Preferred Date:</strong> @Model.PreferredDate.ToShortDateString()</p>
        
        <a asp-action="Status" asp-route-referenceNumber="@Model.ReferenceNumber" class="btn btn-primary">Check Status</a>
    </div>
</div>
