@model ServiceCity.Models.TrackViewModel
@{
    ViewData["Title"] = "Track Booking";
}

<h2 class="h4 mb-4">Track Your Booking</h2>

<form asp-action="Lookup" method="post" class="row g-3">
    @Html.AntiForgeryToken()
    <div class="col-md-6">
        <label asp-for="PhoneNumber" class="form-label">Enter your phone number</label>
        <input asp-for="PhoneNumber" class="form-control" required placeholder="09xxxxxxxxx" />
        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
    </div>
    <div class="col-12">
        <button type="submit" class="btn btn-primary">Find Booking</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
