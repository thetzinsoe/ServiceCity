@model ServiceCity.Models.TrackViewModel
@{
    ViewData["Title"] = "Track Booking";
    var isAdmin = User.IsInRole("Admin");
    var placeholder = isAdmin ? "Phone, name, address, or reference…" : "Phone number or reference…";
}

<div class="page-header">
    <h2 class="page-title">Track Booking</h2>
</div>

<form asp-action="Lookup" method="post" class="row g-3">
    @Html.AntiForgeryToken()
    <div class="col-md-8">
        <input asp-for="SearchTerm" class="form-control" required placeholder="@placeholder" />
        <span asp-validation-for="SearchTerm" class="text-danger"></span>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">Search</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
