@model IEnumerable<ServiceCity.Core.Entities.Booking>
@{
    ViewData["Title"] = "Your Bookings";
}

<h2 class="h4 mb-4">Your Bookings</h2>

@if (!Model.Any())
{
    <p>No bookings found for this phone number.</p>
}
else
{
    <div class="list-group">
        @foreach (var booking in Model)
        {
            <a asp-action="Status" asp-route-referenceNumber="@booking.ReferenceNumber" class="list-group-item list-group-item-action">
                <div class="d-flex w-100 justify-content-between">
                    <h5 class="mb-1">@booking.ReferenceNumber</h5>
                    <small>@booking.CreatedAt.ToShortDateString()</small>
                </div>
                <p class="mb-1">@booking.ServiceCategory.Name - @booking.Status</p>
            </a>
        }
    </div>
}
