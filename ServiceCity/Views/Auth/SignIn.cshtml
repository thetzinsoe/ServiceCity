@model SignInViewModel
@{
    ViewData["Title"] = "Sign In";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <h3 class="card-title text-center mb-3">Sign In</h3>

                @if (TempData["SuccessMessage"] is string successMessage)
                {
                    <div class="alert alert-success">@successMessage</div>
                }

                @if (TempData["InfoMessage"] is string infoMsg)
                {
                    <div class="alert alert-info border-0" style="background:#e7f0fd; color:#1877F2; border-radius:8px;">
                        @infoMsg
                    </div>
                }

                <form asp-action="SignIn" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Username" class="form-label">Username</label>
                        <input asp-for="Username" class="form-control" />
                        <span asp-validation-for="Username" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">Password</label>
                        <input asp-for="Password" class="form-control" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100" style="min-height: 48px;">Sign In</button>
                </form>

                <div class="text-center mt-3">
                    <span class="text-muted">Don't have an account?</span>
                    <a asp-action="Register">Create one</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
