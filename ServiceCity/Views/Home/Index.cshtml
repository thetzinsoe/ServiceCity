@model List<ServiceCity.Core.Entities.ServiceCategory>
@{
    ViewData["Title"] = "ServiceCity";
}

<div class="text-center mb-4">
    <h1 class="display-5 fw-bold">ServiceCity</h1>
    <p class="lead text-muted">AC service booking — fast, simple, reliable.</p>
</div>

<h2 class="h4 mb-3">Our Services</h2>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-warning">No service categories available.</div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 g-3">
        @foreach (var category in Model)
        {
            <div class="col">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title">@category.Name</h5>
                        @if (!string.IsNullOrEmpty(category.Description))
                        {
                            <p class="card-text text-muted">@category.Description</p>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
