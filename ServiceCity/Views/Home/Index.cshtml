@model List<ServiceCity.Core.Entities.ServiceCategory>
@{
    ViewData["Title"] = "ServiceCity";
}

<div class="hero text-center">
    <h1 class="display-5 fw-bold mb-2">AC Service, Booked.</h1>
    <p class="lead mb-0">Tell us what's wrong, pick a time, and we'll be there. No phone calls, no guesswork.</p>
</div>

<h2 class="h5 fw-bold mb-3">What do you need?</h2>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-warning">No service categories available.</div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 g-3">
        @foreach (var category in Model)
        {
            <div class="col">
                <div class="card h-100 service-card">
                    <div class="card-body">
                        <div class="icon-circle">
                            @(category.Name switch
                            {
                                "Repair" => "🔧",
                                "Maintenance" => "🧹",
                                "Installation" => "📦",
                                "Gas Refill" => "❄️",
                                _ => "🔩"
                            })
                        </div>
                        <h5 class="card-title">@category.Name</h5>
                        @if (!string.IsNullOrEmpty(category.Description))
                        {
                            <p class="card-text text-muted">@category.Description</p>
                        }
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a asp-controller="Booking" asp-action="Create" asp-route-serviceCategoryId="@category.Id"
                               class="btn btn-primary px-4">
                                Book Now
                            </a>
                        }
                        else
                        {
                            <a asp-controller="Auth" asp-action="SignIn"
                               class="btn btn-outline-primary px-4">
                                Sign In to Book
                            </a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
