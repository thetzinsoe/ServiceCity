      "Bash(ln -sf ~/.cache/ms-playwright/chromium-1228/chrome-linux64/chrome /tmp/google-chrome/chrome)",
      "Bash(export PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/tmp/google-chrome/chrome)",
      "mcp__plugin_playwright_playwright__browser_run_code_unsafe",
      "Bash(sudo ln -sf ~/.cache/ms-playwright/chromium-1228/chrome-linux64/chrome /opt/google/chrome/chrome)",
      "Bash(curl -s http://localhost:5124/)",
      "Bash(curl *)",
      "Bash(docker compose logs *)",
      "Bash(docker exec servicecity-db *)",
      "Bash(git add *)",
      "Bash(git commit -m 'docs: add screenshots to README at top section *)",
      "Bash(git push *)",
      "Bash(git pull *)",
      "Bash(git stash *)",
      "Bash(npm install *)",
      "Bash(git commit -m 'docs: replace track screenshot, add admin dashboard, confirmation, and status timeline *)",
